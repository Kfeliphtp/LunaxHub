local cooldown6 = {}

local function autoBuy6Func()
	for _,v in pairs(workspace:GetDescendants()) do
		if v:IsA("ProximityPrompt") then

			for raridade6,ativo6 in pairs(autoBuy6) do

				if ativo6 and lists6[raridade6] and lists6[raridade6][v.ObjectText] then

					if not cooldown6[v] then
						cooldown6[v] = true

						fireproximityprompt(v, 1)

						task.delay(2,function()
							cooldown6[v] = nil
						end)
					end
				end
			end
		end
	end
end

task.spawn(function()
	while true do
		task.wait(0.2)
		pcall(autoBuy6Func)
	end
end)
