-- FUNÇÃO PROTEGER
local function protegerChar(char)
	local hrp = char:WaitForChild("HumanoidRootPart")

	-- tamanho padrão
	local normalSize = Vector3.new(2,2,1)

	-- loop proteção
	task.spawn(function()
		while AntiAtivo and hrp and hrp.Parent do
			if hrp.Size ~= normalSize then
				hrp.Size = normalSize
			end

			if hrp.Transparency ~= 1 then
				hrp.Transparency = 1
			end

			task.wait(0.1)
		end
	end)

	-- proteção instantânea (quando tentam mudar)
	hrp:GetPropertyChangedSignal("Size"):Connect(function()
		if AntiAtivo then
			hrp.Size = normalSize
		end
	end)
end

-- quando spawnar
if player.Character then
	protegerChar(player.Character)
end

player.CharacterAdded:Connect(function(char)
	task.wait(1)
	protegerChar(char)
end)
