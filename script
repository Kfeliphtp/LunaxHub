local espPlayersAtivo = false
local playerHighlights = {}
local player = game.Players.LocalPlayer

local function criarNomePlayer(character, player)
	if not character or character:FindFirstChild("NameESP") then return end

	local head = character:FindFirstChild("Head")
	if not head then return end

	local bill = Instance.new("BillboardGui")
	bill.Name = "NameESP"
	bill.Size = UDim2.new(0, 100, 0, 25)
	bill.StudsOffset = Vector3.new(0, 2.5, 0)
	bill.AlwaysOnTop = true
	bill.Parent = head

	local text = Instance.new("TextLabel")
	text.Size = UDim2.new(1, 0, 1, 0)
	text.BackgroundTransparency = 1
	text.Text = player.Name
	text.TextColor3 = Color3.fromRGB(255, 255, 255)
	text.TextStrokeTransparency = 0
	text.TextScaled = true
	text.Font = Enum.Font.SourceSansBold
	text.Parent = bill
end

local function criarESPPlayer(character)
	if not character or character:FindFirstChild("PlayerESP") then return end

	local highlight = Instance.new("Highlight")
	highlight.Name = "PlayerESP"
	highlight.FillColor = Color3.fromRGB(0, 0, 255)
	highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
	highlight.FillTransparency = 0.4
	highlight.OutlineTransparency = 0.5
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop

	highlight.Parent = character
	table.insert(playerHighlights, highlight)
end

local function removerESPPlayers()
	for _, h in pairs(playerHighlights) do
		if h then
			h:Destroy()
		end
	end
	playerHighlights = {}

	-- remove nomes
	for _, plr in pairs(game.Players:GetPlayers()) do
		if plr.Character then
			local name = plr.Character:FindFirstChild("Head") and plr.Character.Head:FindFirstChild("NameESP")
			if name then
				name:Destroy()
			end
		end
	end
end

local function aplicarESPPlayers()
	for _, plr in pairs(game.Players:GetPlayers()) do
		if plr ~= player then
			if plr.Character then
				criarESPPlayer(plr.Character)
				criarNomePlayer(plr.Character, plr)
			end
		end
	end
end

game.Players.PlayerAdded:Connect(function(plr)
	plr.CharacterAdded:Connect(function(char)
		if espPlayersAtivo then
			task.wait(1)
			criarESPPlayer(char)
		end
	end)
end)

-- BOTÃO CERTO
EspButton.MouseButton1Click:Connect(function()
	espPlayersAtivo = not espPlayersAtivo

	EspButton.Text = espPlayersAtivo and "▣" or "☐"

	if espPlayersAtivo then
		aplicarESPPlayers()
	else
		removerESPPlayers()
	end
end)

