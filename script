function fecharTudo()

	AutoFarmAberto.Visible = false
	PlayersAberto.Visible = false
end

ButtonOpen.MouseButton1Click:Connect(function()
	ImgPanelHub.Visible = false
	ImgPanelConfig.Visible = true

	fecharTudo()
end)

ButtonPrimario.MouseButton1Click:Connect(function()
	if ImgPanelHub.Visible or ImgPanelConfig.Visible then
		ImgPanelHub.Visible = false
		ImgPanelConfig.Visible = false
		fecharTudo()
	else
		ImgPanelHub.Visible = true
		ImgPanelConfig.Visible = false
	end
end)

local dragging = false
local dragStart
local startPos

ButtonPrimario.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = ButtonPrimario.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart

		ButtonPrimario.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)
